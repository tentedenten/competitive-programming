int r = 0;
// 状態を管理する変数（例：現在の和、個数など）
long long current_state = 0; 

for (int l = 0; l < n; ++l) {
    // 1. r を動かせるだけ動かす
    while (r < n && /* r 番目を追加しても条件を満たすか */) {
        /* current_state に a[r] を加える処理 */
        r++;
    }

    // 2. この時点で [l, r) が条件を満たす最大の範囲
    // ここで答えを更新する
    ans += (r - l); // 例：条件を満たす区間の個数

    // 3. 次の l のために準備（l 番目の要素を外す）
    if (r == l) {
        // r が l を追い越さないように調整（空集合のときなど）
        r++; 
    } else {
        /* current_state から a[l] を除外する処理 */
    }
}
